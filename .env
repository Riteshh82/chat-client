
REACT_APP_BACKEND_URL=http://localhost:5001

# GNews API key (free at https://gnews.io — 100 req/day free)
# OR use NewsData.io (https://newsdata.io — 200 req/day free)
REACT_APP_NEWS_API_KEY=your_gnews_api_key_here

# Optional: change news category (technology | world | sports | science | health | business)
REACT_APP_NEWS_CATEGORY=technology
